NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

NIM_API_KEY=your_nvidia_nim_key

# Social login. Leave blank/unset until the matching provider is enabled in
# Supabase Dashboard → Authentication → Providers. When enabled, set to "true"
# and the Google/Microsoft buttons will appear on /auth/login.
NEXT_PUBLIC_OAUTH_GOOGLE_ENABLED=
NEXT_PUBLIC_OAUTH_AZURE_ENABLED=

# Optional. Leave blank until Stripe payments are enabled.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional. Override the premium price in pence (default 799 = £7.99).
STRIPE_PRICE_PENCE=
